# Base networking: TCP/IP stack, IPv6, sockets, 9p, basic NIC drivers.
# Container networking (netfilter, nftables, bridge, ipvs, traffic control)
# lives in apps/docker/kernel/net and apps/runc/kernel/net.

# === Disables from old base config ===
# CONFIG_6LOWPAN_DEBUGFS is not set
# CONFIG_6LOWPAN_GHC_EXT_HDR_DEST is not set
# CONFIG_6LOWPAN_GHC_EXT_HDR_FRAG is not set
# CONFIG_6LOWPAN_GHC_EXT_HDR_HOP is not set
# CONFIG_6LOWPAN_GHC_EXT_HDR_ROUTE is not set
# CONFIG_6LOWPAN_GHC_ICMPV6 is not set
# CONFIG_6LOWPAN_GHC_UDP is not set
# CONFIG_8139TOO_PIO is not set
# CONFIG_NET_KEY_MIGRATE is not set
# CONFIG_NF_CONNTRACK_PROCFS is not set

# === Core networking ===
CONFIG_NET=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# === Basic IP features ===
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_IP_PNP_BOOTP=y

# === IPv6 basics ===
CONFIG_IPV6_ROUTER_PREF=y
CONFIG_IPV6_ROUTE_INFO=y
CONFIG_IPV6_SUBTREES=y

# === Common Ethernet drivers ===
CONFIG_8139CP=m
CONFIG_8139TOO=m
CONFIG_8139TOO_8129=y
CONFIG_8139TOO_TUNE_TWISTER=y

# === TCP congestion (basic) ===
CONFIG_MPTCP=y

# === 9p networking ===
CONFIG_NET_9P=m

# === Misc ===
CONFIG_NET_DROP_MONITOR=y
CONFIG_IPC_NS=y
CONFIG_NET_NS=y
CONFIG_NETLINK_DIAG=m
CONFIG_INET_DIAG=m
CONFIG_INET_DIAG_DESTROY=y
CONFIG_INET_RAW_DIAG=m
CONFIG_INET_UDP_DIAG=m
CONFIG_INET_DCCP_DIAG=m
CONFIG_INET_SCTP_DIAG=m
