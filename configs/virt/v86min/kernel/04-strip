# v86-minimal: strip beyond browser/v86 base.
# browser/v86 handles: wireless, BT, BPF, RFKILL, HWMON, ZRAM, misc.
# This handles: USB, sound, and deeper stripping.

# === Cgroups: minimal set for systemd ===
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
# CONFIG_CGROUP_PIDS is not set
# CONFIG_CGROUP_FREEZER is not set
# CONFIG_CGROUP_DEVICE is not set
# CONFIG_CGROUP_CPUACCT is not set
# CONFIG_CGROUP_PERF is not set
# CONFIG_CGROUP_HUGETLB is not set
# CONFIG_CGROUP_RDMA is not set
# CONFIG_CGROUP_MISC is not set
# CONFIG_CGROUP_DEBUG is not set
# CONFIG_CGROUP_BPF is not set
# CONFIG_CGROUP_NET_PRIO is not set
# CONFIG_MEMCG is not set
# CONFIG_BLK_CGROUP is not set
# CONFIG_CFS_BANDWIDTH is not set
# CONFIG_CPUSETS is not set

# === USB: entire subsystem ===
# CONFIG_USB_SUPPORT is not set
# CONFIG_USB is not set

# === HID specialty drivers ===
# CONFIG_HID_A4TECH is not set
# CONFIG_HID_BELKIN is not set
# CONFIG_HID_CHERRY is not set
# CONFIG_HID_CYPRESS is not set
# CONFIG_HID_EZKEY is not set
# CONFIG_HID_ITE is not set
# CONFIG_HID_KENSINGTON is not set
# CONFIG_HID_REDRAGON is not set
# CONFIG_HID_MICROSOFT is not set
# CONFIG_HID_MONTEREY is not set
# CONFIG_USB_HID is not set
# CONFIG_HIDRAW is not set

# === Sound (browser/v86 keeps this, we strip) ===
# CONFIG_SOUND is not set
# CONFIG_SND is not set

# === Networking diag (not needed) ===
# CONFIG_NETLINK_DIAG is not set
# CONFIG_INET_DIAG is not set
# CONFIG_NET_DROP_MONITOR is not set

# === Misc v86min-specific ===
